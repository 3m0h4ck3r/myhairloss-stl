# Resend API key for sending booking/contact emails
# Get one at https://resend.com
RESEND_API_KEY=

# Lemon Squeezy — payment processing
# Sign up at https://lemonsqueezy.com
# 1. Get your API key from Settings > API
LEMONSQUEEZY_API_KEY=
# 2. Find your Store ID in Settings > Stores
LEMONSQUEEZY_STORE_ID=
# 3. Set a webhook secret in Settings > Webhooks
#    URL: https://myhairloss.com/api/store/webhook
#    Events: order_created, subscription_*
LEMONSQUEEZY_WEBHOOK_SECRET=
